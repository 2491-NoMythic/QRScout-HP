        {
          "title": "Alliance Scouted",
          "description": "The Color of the alliance you are scouting.",
          "type": "select",
          "required": true,
          "code": "teamNumber1",
          "formResetBehavior": "preserve",
          "defaultValue": "",
          "choices": {
            "B": "Blue Alliance",
            "R": "Red Alliance"
          }
        },
        {
          "title": "Type of Match",
          "description": "The type of match being played.",
          "type": "select",
          "required": true,
          "code": "MatchType",
          "formResetBehavior": "preserve",
          "defaultValue": "",
          "choices": {
            "Practice": "Practice",
            "Qualifications": "Qualifications"
          }
        },
        {
          "title": "Match Number",
          "description": "The match number of the match being played.",
          "type": "number",
          "required": true,
          "code": "matchNumber",
          "formResetBehavior": "increment",
          "defaultValue": 1
        }
      ]
    },
    {
